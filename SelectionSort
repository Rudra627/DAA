// Online C compiler to run C program online
#include <stdio.h>
int main() {
    int size;
  printf("Enter the size of array:");
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++){
      printf("Enter the %d element:",i);
      scanf("%d",&arr[i]);
  }
  printf("Before Sort\n");
  
  for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
  }
  for(int i=0;i<size;i++){
      int minidx=i;
      for(int j=i+1;j<size;j++){
          if(arr[j]<arr[minidx]){
              minidx=j;
      }
   
  }   
     int temp=arr[i];
      arr[i]=arr[minidx];
      arr[minidx]=temp;
  }
   printf("\n After sort:\n");
      for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
      }
    return 0;
}
