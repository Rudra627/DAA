#include <stdio.h>
#include <stdbool.h>
bool isSorted(int arr[],int x){
    int co=0;
    for(int i=0;i<x;i++){
        if(arr[i]<arr[i+1]){
            co++;
        }
    }
    if(co==x-1){
        return true;
    }
    else{
        return false;
    }
}
int main() {
    int size;
  printf("Enter the size of array:");
