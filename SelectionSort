  for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
  }
  for(int i=0;i<size;i++){
      int minidx=i;
      for(int j=i+1;j<size;j++){
          if(arr[j]<arr[minidx]){
              minidx=j;
      }
   
  }   
     int temp=arr[i];
      arr[i]=arr[minidx];
      arr[minidx]=temp;
  }
   printf("\n After sort:\n");
