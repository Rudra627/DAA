
#include <stdio.h>
int main() {
  int size;
  printf("Enter the size of array:");
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++){
      printf("Enter the %d element:",i);
      scanf("%d",&arr[i]);
  }
  printf("Before Sort\n");
  
  for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
  }
  for(int i=0;i<size;i++){
      for(int j=0;j<size-1;j++){
          if(arr[j]>arr[j+1]){
              int temp=arr[j];
              arr[j]=arr[j+1];
              arr[j+1]=temp;
          }
      }
  }
   printf("\n After sort:\n");
      for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
      
  }
    return 0;
}
