
#include <stdio.h>
#include <stdbool.h>
bool isSorted(int arr[],int x){
    int co=0;
    for(int i=0;i<x;i++){
        if(arr[i]<arr[i+1]){
            co++;
        }
    }
    if(co==x-1){
        return true;
    }
    else{
        return false;
    }
}
int main() {
  int size;
  printf("Enter the size of array:");
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++){
      printf("Enter the %d element:",i);
      scanf("%d",&arr[i]);
  }
  if(isSorted(arr,size)){
      printf("Array is Alrady Sorted\n");
  }
  printf("Before Sort\n");
  
  for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
  }
  for(int i=0;i<size;i++){
      for(int j=0;j<size-1;j++){
          if(arr[j]>arr[j+1]){
              int temp=arr[j];
              arr[j]=arr[j+1];
              arr[j+1]=temp;
          }
      }
  }
   printf("\n After sort:\n");
      for(int i=0;i<size;i++){
      printf("%d ",arr[i]);
      
  }
    return 0;
}
